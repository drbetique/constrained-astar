# OAuth client credentials JSON downloaded from Google Cloud console
GOOGLE_CREDENTIALS_FILE=credentials.json
# Will be created after first login; do not commit
GOOGLE_TOKEN_FILE=token.json

# Gmail settings
GMAIL_USER_ID=me
GMAIL_QUERY=is:unread newer_than:7d
GMAIL_MAX_MESSAGES=20
# Optional: set to a label name to add after processing
GMAIL_PROCESSED_LABEL=Processed/ToSheet

# Google Sheets settings
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_RANGE=Sheet1!A:C
GOOGLE_SHEETS_VALUE_INPUT_OPTION=USER_ENTERED

# Behavior
DRY_RUN=1
